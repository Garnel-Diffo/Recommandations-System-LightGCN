# Copier ce fichier en ".env" et renseigner les valeurs réelles.

# Environnement Flask : "development" ou "production"
FLASK_ENV=development

# Chaîne de connexion PostgreSQL (Neon)
# Format : postgresql://<user>:<password>@<host>/<database>?sslmode=require
DATABASE_URL=postgresql://neondb_owner:npg_5TtqD7UyOQxg@ep-rough-queen-asehowo6.c-4.eu-central-1.aws.neon.tech/neondb?sslmode=require

# Clé API TMDb (gratuite) : https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Origines autorisées pour le frontend (CORS), séparées par des virgules
CORS_ORIGINS=http://localhost:3000

# Port d'écoute local (Render fournit automatiquement sa propre variable PORT)
PORT=5000

# Nombre de recommandations par défaut / maximum
DEFAULT_TOP_K=10
MAX_TOP_K=50
