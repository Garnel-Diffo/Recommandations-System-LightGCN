# =====================================================================
# Recommandations-System — fichiers ignorés par Git
# =====================================================================

# ---------------------------------------------------------------------
# Variables d'environnement (secrets)
# ---------------------------------------------------------------------
.env
.env.*
!.env.example
!*/.env.example

# ---------------------------------------------------------------------
# Python (notebook, backend)
# ---------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.ipynb_checkpoints/

# ---------------------------------------------------------------------
# Notebook : données volumineuses (re-téléchargeables) et artefacts
# ---------------------------------------------------------------------
# notebook/data/
# notebook/models/*.npy
# notebook/models/*.pt

# ---------------------------------------------------------------------
# Node / Next.js (frontend)
# ---------------------------------------------------------------------
node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/next-env.d.ts
*.tsbuildinfo

# ---------------------------------------------------------------------
# Logs
# ---------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------
# Éditeurs / OS
# ---------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
Thumbs.db
